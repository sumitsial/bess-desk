# LLM provider
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Default LLM model for agents
BESS_DESK_LLM_PROVIDER=anthropic
BESS_DESK_LLM_MODEL=claude-sonnet-4-5

# Database (SQLite by default, Postgres for production)
BESS_DESK_DB_URL=sqlite:///./bess_desk.db

# Market mode: replay | live | sim
BESS_DESK_MARKET_MODE=replay

# Auto-approve mode (dangerous — only for backtests)
BESS_DESK_AUTO_APPROVE=false

# Live market tokens (only needed for --mode live)
# ENTSOE_API_TOKEN=
# REGELLEISTUNG_API_TOKEN=
